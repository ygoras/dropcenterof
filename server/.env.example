# Database
DATABASE_URL=postgresql://dropcenter:your_password@localhost:5432/dropcenter

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Legacy JWT (optional, can remove after full migration)
# JWT_SECRET=your-jwt-secret-min-32-chars-long-here

# App
APP_URL=https://yourdomain.com
APP_PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com

# MinIO Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_USE_SSL=false

# Mercado Livre
ML_APP_ID=your_ml_app_id
ML_CLIENT_SECRET=your_ml_client_secret
ML_WEBHOOK_SECRET=your_ml_webhook_secret

# Asaas
ASAAS_API_KEY=your_asaas_api_key
ASAAS_WEBHOOK_TOKEN=your_asaas_webhook_token
ASAAS_SANDBOX=true

# Billing
BILLING_CRON_SECRET=your_billing_cron_secret

# Encryption (for PIX data at rest)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
